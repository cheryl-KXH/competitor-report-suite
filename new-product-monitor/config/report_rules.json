  "categoryRule": {
    "description": "品类只显示一个。优先级：茶特调 > 果蔬茶 > 柠檬茶 > 酒元素 > 主品类。",
    "additionalField": "additionalCategory",
    "mainField": "mainCategory",
    "priority": ["茶特调", "果蔬茶", "柠檬茶", "酒元素"],
    "fallback": "mainCategory",
    "separator": "、"
  },
  "remarkRule": {
    "order": ["returnStatus", "collaboration", "remark"],
    "separator": "，",
    "emptyText": "/",
    "returnStatus": {
      "showValue": "回归",
      "truthyValues": ["回归", "是", "true", "TRUE", "1"],
      "ignoredValues": ["上新", "否", "false", "FALSE", "0"]
    },
    "collaboration": {
      "suffix": "联名"
    }
  },
  "priceRule": {
    "strikeParenthesizedPrice": true,
    "parenthesizedPricePattern": "\\d+(?:\\.\\d+)?\\s*元",
    "summaryWrapAfterSlash": true
  },
  "dataQualityRule": {
    "enabled": true,
    "continueOnWarning": true,
    "warnMissingImages": true,
    "requiredTextFields": {
      "category": "品类",
      "productName": "新品名称",
      "launchDate": "上市日期",
      "price": "产品价格",
      "sellingPoint": "产品卖点介绍",
      "ingredients": "原料构成"
    }
  },
  "sort": {
    "brandOrder": "defaultBrands",
    "withinBrand": ["launchDate", "series", "tableOrder"]
  }
}
